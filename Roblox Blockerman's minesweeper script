-- TOGGLE BUTTON LOGIC
toggleButton.MouseButton1Click:Connect(function()
	if isScanning then
		-- Turn OFF
		isScanning = false
		toggleButton.Text = "START"
		toggleButton.TextColor3 = Color3.fromRGB(0, 255, 0)
		statusLabel.Text = "Status: Offline"
		statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
		
		for _, conn in pairs(connections) do conn:Disconnect() end
		connections = {}
		
		for _, p in pairs(cachedParts) do if p.Parent then clearVisuals(p) end end
		
		cachedParts = {}
		neighborMap = {}
		numberTiles = {}
		knownMines = {}
		knownSafe = {}
		currentBestGuess = nil
	else
		-- Turn ON
		isScanning = true
		toggleButton.Text = "STOP"
		toggleButton.TextColor3 = Color3.fromRGB(255, 0, 0)
		statusLabel.Text = "Status: Scanning..."
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
		
		cachedParts = {}
		neighborMap = {}
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name == "Part" then 
				table.insert(cachedParts, obj)
				cacheNeighbors(obj)
			end
		end
		
		table.insert(connections, workspace.DescendantAdded:Connect(onDescendantAdded))
		startSolverLoop()
	end
end)

-- FAST BUTTON LOGIC (Teleport to Safe Blocks)
fastButton.MouseButton1Click:Connect(function()
	if not isScanning then return end
	
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	local root = char.HumanoidRootPart
	
	-- Collect safe parts
	local safeParts = {}
	for part, _ in pairs(knownSafe) do
		if part and part.Parent and isUnrevealed(part) then
			table.insert(safeParts, part)
		end
	end
	
	if #safeParts == 0 then return end
	
	statusLabel.Text = "Status: Teleporting..."
	
	-- Teleport loop with EMERGENCY BREAK
	for _, part in ipairs(safeParts) do
		-- CRITICAL FIX: Stop teleporting if user turned off the script
		if not isScanning then break end 
		
		if part.Parent then
			-- Calculate Top Surface: Center + (Half Height) + Buffer (3 studs)
			local topOffset = (part.Size.Y / 2) + 3
			root.CFrame = part.CFrame + Vector3.new(0, topOffset, 0)
			
			task.wait(0.05) -- Speed
		end
	end
	
	if isScanning then
		statusLabel.Text = "Status: Scanning..."
	end
end)

destroyButton.MouseButton1Click:Connect(function()
	isScanning = false
	for _, conn in pairs(connections) do conn:Disconnect() end
	screenGui:Destroy()
end)
