toggleButton.MouseButton1Click:Connect(function()
	if isScanning then
		isScanning = false
		isFastTPing = false
		pendingReset = false -- Ensure it doesn't get stuck
		
		toggleButton.Text = "START"
		toggleButton.TextColor3 = Color3.fromRGB(0, 255, 0)
		fastButton.Text = "FAST TP: OFF"
		fastButton.TextColor3 = Color3.fromRGB(0, 255, 255)
		statusLabel.Text = "Status: Offline"
		statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
		
		for _, conn in pairs(connections) do conn:Disconnect() end
		connections = {}
		for _, p in pairs(cachedParts) do if p:IsDescendantOf(workspace) then clearVisuals(p) end end
		cachedParts = {}; neighborMap = {}; numberTiles = {}; knownMines = {}; knownSafe = {}; currentBestGuess = nil
	else
		isScanning = true
		toggleButton.Text = "STOP"
		toggleButton.TextColor3 = Color3.fromRGB(255, 0, 0)
		statusLabel.Text = "Status: Scanning..."
		statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
		
		cachedParts = {}; neighborMap = {}
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj.Name == "Part" then 
				table.insert(cachedParts, obj)
				cacheNeighbors(obj, false)
			end
		end
		table.insert(connections, workspace.DescendantAdded:Connect(onDescendantAdded))
		startSolverLoop()
	end
end)

fastButton.MouseButton1Click:Connect(function()
	if not isScanning then return end
	
	isFastTPing = not isFastTPing 
	
	if isFastTPing then
		fastButton.Text = "FAST TP: ON"
		fastButton.TextColor3 = Color3.fromRGB(0, 255, 0)
		statusLabel.Text = "Status: Fast TP Active"
		
		task.spawn(function()
			while isFastTPing and isScanning do
				if not pendingReset then
					local char = player.Character
					local root = char and char:FindFirstChild("HumanoidRootPart")
					
					if root then
						local safeParts = {}
						for part, _ in pairs(knownSafe) do
							if part and part:IsDescendantOf(workspace) and isUnrevealed(part) then
								table.insert(safeParts, part)
							end
						end
						
						if #safeParts > 0 then
							for _, part in ipairs(safeParts) do
								if not isFastTPing or not isScanning or pendingReset then break end 
								
								if part:IsDescendantOf(workspace) and isUnrevealed(part) then
									local topOffset = (part.Size.Y / 2) + 3
									root.CFrame = part.CFrame + Vector3.new(0, topOffset, 0)
									task.wait(0.05) 
								end
							end
						else
							task.wait(0.1) 
						end
					else
						task.wait(0.1)
					end
				else
					task.wait(0.1) 
				end
			end
			
			isFastTPing = false
			fastButton.Text = "FAST TP: OFF"
			fastButton.TextColor3 = Color3.fromRGB(0, 255, 255)
			if isScanning then statusLabel.Text = "Status: Scanning..." end
		end)
	else
		isFastTPing = false
		fastButton.Text = "FAST TP: OFF"
		fastButton.TextColor3 = Color3.fromRGB(0, 255, 255)
		statusLabel.Text = "Status: Scanning..."
	end
end)

