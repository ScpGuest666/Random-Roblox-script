		antiLagButton.Text = "ANTI-LAG: ON"
		antiLagButton.TextColor3 = Color3.fromRGB(0, 255, 0)
	else
		antiLagButton.Text = "ANTI-LAG: OFF"
		antiLagButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	end
end)

